# App server
APP_PORT=8080
APP_ORIGIN=http://localhost:8080

# Entra app settings (default demo tenant)
CLIENT_ID=48a52df3-eefa-4c31-aacb-7cc69ebc2166
TENANT_ID=23524f33-8f73-42a8-8246-12ab4e74d324
TENANT_SUBDOMAIN=TakedaIDtst
ENTRA_AUTHORITY_HOST=ciamlogin.com

# Optional explicit authority override
# AUTHORITY=https://TakedaIDtst.ciamlogin.com/23524f33-8f73-42a8-8246-12ab4e74d324

# Native Auth API target configuration
LOCAL_API_PATH=/api
CORS_PORT=3001
# Optional explicit target override (wins over TENANT_SUBDOMAIN/TENANT_ID)
# PROXY_TARGET=https://TakedaIDtst.ciamlogin.com/23524f33-8f73-42a8-8246-12ab4e74d324
# Set to true only for local troubleshooting when corporate TLS inspection breaks upstream validation.
ALLOW_INSECURE_TLS=false

# Browser-facing API URL override (optional)
PUBLIC_BASE_API_URL=http://localhost:3001/api

# OAuth redirect
REDIRECT_URI=http://localhost:8080

# UI locale
LOCALE=en

# Default UI theme (azure-portal | enterprise-blue | fintech-slate)
THEME=azure-portal

# Demo/security flags
DEMO_MODE=false
ENABLE_OPERATOR_MODE=false
ENABLE_BETA_GRAPH=false
LOOKUP_RECOVERY_ENABLED=false
LOOKUP_DISCLOSURE_MODE=masked-email
LOOKUP_PHONE_SOURCE=mobilePhone

# Backend lookup app registration for phone-based email recovery
LOOKUP_APP_CLIENT_ID=3879af56-4888-43e8-a6ab-46c3ca29c98c
LOOKUP_APP_CLIENT_SECRET=YOUR_LOOKUP_APP_CLIENT_SECRET
LOOKUP_APP_TENANT_ID=78a77549-78e5-49f7-a870-9efbb0d32d91
LOOKUP_GRAPH_SCOPE=https://graph.microsoft.com/.default

# Comma-separated delegated scopes
LOGIN_SCOPES=openid,profile,email,User.Read,UserAuthenticationMethod.Read,UserAuthMethod-Phone.ReadWrite

# Native Auth defaults
NATIVE_AUTH_SCOPES=openid offline_access User.Read UserAuthenticationMethod.Read UserAuthMethod-Phone.ReadWrite
NATIVE_AUTH_CAPABILITIES=registration_required mfa_required
NATIVE_AUTH_SIGNIN_CHALLENGE_TYPE=password oob redirect
NATIVE_AUTH_SIGNUP_CHALLENGE_TYPE=oob password redirect
NATIVE_AUTH_RESET_PASSWORD_CHALLENGE_TYPE=oob redirect
SIGNUP_ENABLED_ATTRIBUTES=displayName,givenName,surname,city,country,postalCode,state,streetAddress,jobTitle,username
SIGNUP_REQUIRED_ATTRIBUTES=
SIGNUP_SHOW_ADVANCED_JSON=false
SIGNUP_FIELD_OVERRIDES=
SIGNUP_ATTRIBUTE_TEMPLATE=

# cors_prod origin allowlist (comma-separated)
ALLOWED_ORIGINS=http://localhost:8080